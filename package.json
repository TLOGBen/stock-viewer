{
  "name": "twse-trading-desk-desktop",
  "version": "1.0.3",
  "private": true,
  "description": "Desktop (Electron) wrapper for the Taiwan real-time trading desk.",
  "main": "electron/main.js",
  "author": "Taiwan Trading Desk",
  "homepage": "https://github.com/TLOGBen/stock-viewer",
  "scripts": {
    "build:server": "node server/scripts/bundle.mjs",
    "build:web": "cross-env ELECTRON_BUILD=1 npm --prefix web run generate",
    "build:all": "npm run build:server && npm run build:web",
    "electron:dev": "npm run build:all && electron .",
    "dist:win": "npm run build:all && electron-builder --win --x64",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:linux": "npm run build:all && electron-builder --linux",
    "dist:dir": "npm run build:all && electron-builder --dir",
    "release:win": "npm run build:all && electron-builder --win --x64 --publish always",
    "release:mac": "npm run build:all && electron-builder --mac --publish always",
    "release:linux": "npm run build:all && electron-builder --linux --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "io.github.twse.tradingdesk",
    "productName": "即時交易台",
    "copyright": "© 2026 Taiwan Trading Desk",
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron/build"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "server/bundle",
        "to": "server/bundle"
      },
      {
        "from": "web/.output/public",
        "to": "web/public"
      }
    ],
    "win": {
      "icon": "electron/build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "即時交易台",
      "include": "electron/build/installer.nsh"
    },
    "mac": {
      "icon": "electron/build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.finance"
    },
    "linux": {
      "icon": "electron/build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "synopsis": "即時台股交易台 — Taiwan real-time trading desk",
      "maintainer": "Taiwan Trading Desk <noreply@users.noreply.github.com>"
    }
  }
}
