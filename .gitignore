# dependencies
node_modules/

# build output
server/dist/
server/bundle/
web/.nuxt/
web/.output/
web/dist/

# electron desktop packaging output
dist-electron/

# nuxt
web/.data/
.nitro/
.cache/

# env / secrets
.env
.env.*
!.env.example

# logs
*.log
npm-debug.log*

# os / editor
.DS_Store
.idea/
.vscode/
*.local

# runtime data (re-created on first run: universe cache, persisted watchlist,
# per-symbol k-line cache). store.ts / universe cache / historyCache mkdir it.
server/data/

# agent / tooling workspace (research digests, scraped material — not app code)
.claude/

# root-level process/design docs (planning, specs, reviews) — keep only the
# app-facing README and the agent guide. Anchored to repo root, so nested docs
# are unaffected.
/*.md
!/README.md
!/CLAUDE.md
